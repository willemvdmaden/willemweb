---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "Postdoctoral Researcher at IT University of Copenhagen, researching AI, Design, and Human-Computer Interaction", ogImage } = Astro.props;
const fullTitle = title === "Willem van der Maden" ? title : `${title} | Willem van der Maden`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = ogImage ? new URL(ogImage, Astro.site).href : new URL("/icon.png", Astro.site).href;

import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Willem van der Maden" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    
    <!-- JSON-LD Structured Data -->
    {fullTitle === "Willem van der Maden" ? (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Willem van der Maden",
        "jobTitle": "Postdoctoral Researcher",
        "affiliation": {
          "@type": "Organization",
          "name": "IT University of Copenhagen"
        },
        "url": "https://willemvandermaden.com",
        "sameAs": [
          "https://scholar.google.com/citations?user=Willem+van+der+Maden"
        ],
        "description": description
      })} />
    ) : (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebPage",
        "name": fullTitle,
        "description": description,
        "url": canonicalURL.href
      })} />
    )}

    <!-- Fonts: Sora (headings) + Lora (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
    
    <ViewTransitions />
  </head>
  <body class="flex flex-col min-h-screen">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-cobalt focus:text-white focus:px-4 focus:py-2 focus:rounded-md">Skip to main content</a>
    <!-- Scroll progress indicator -->
    <div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>

    <!-- Grain overlay -->
    <div class="grain-overlay" aria-hidden="true"></div>
    
    <Header />
    <main id="main-content" class="flex-grow mb-16 md:mb-24" transition:animate="fade">
      <slot />
    </main>
    <Footer />

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function initSmooth() {
        // Scroll progress
        const scrollProgress = document.getElementById('scroll-progress');
        if (scrollProgress) {
          ScrollTrigger.create({
            trigger: document.body,
            start: 'top top',
            end: 'bottom bottom',
            onUpdate: (self) => {
              scrollProgress.style.transform = `scaleX(${self.progress})`;
            },
          });
        }

        if (prefersReducedMotion) {
          // Just show everything immediately
          document.querySelectorAll('[data-hero] h1, [data-hero] [data-subtitle], [data-hero] img, [data-hero] [data-social] a, [data-hero] [data-bio], [data-hero] [data-ctas] a, [data-currently], .publication-card, [data-scroll-reveal]').forEach(el => {
            (el as HTMLElement).style.opacity = '1';
          });
          document.querySelectorAll('.marker-highlight').forEach(el => el.classList.add('revealed'));
          return;
        }

        // Hero animations
        const heroSection = document.querySelector('[data-hero]');
        if (heroSection) {
          const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

          // Profile image
          const profile = heroSection.querySelector('[data-profile] img');
          if (profile) {
            gsap.set(profile, { opacity: 0, scale: 0.8, rotate: -5 });
            tl.to(profile, { opacity: 1, scale: 1, rotate: 0, duration: 0.9 }, 0.1);
          }

          // Name with letter-spacing animation
          const h1 = heroSection.querySelector('h1');
          if (h1) {
            gsap.set(h1, { opacity: 0, y: 30, letterSpacing: '0.15em' });
            tl.to(h1, { opacity: 1, y: 0, letterSpacing: '-0.02em', duration: 1 }, 0.2);
          }

          // Subtitle
          const subtitle = heroSection.querySelector('[data-subtitle]');
          if (subtitle) {
            gsap.set(subtitle, { opacity: 0, y: 20 });
            tl.to(subtitle, { opacity: 1, y: 0, duration: 0.8 }, 0.4);
          }

          // Bio - line by line reveal
          const bio = heroSection.querySelector('[data-bio]');
          if (bio) {
            gsap.set(bio, { opacity: 0, y: 20 });
            tl.to(bio, { opacity: 1, y: 0, duration: 0.8 }, 0.5);
            // Animate marker highlights after bio appears
            const markers = bio.querySelectorAll('.marker-highlight');
            markers.forEach((marker, i) => {
              tl.call(() => marker.classList.add('revealed'), [], 0.9 + i * 0.3);
            });
          }

          // Social links staggered
          const socialLinks = heroSection.querySelectorAll('[data-social] a');
          if (socialLinks.length) {
            gsap.set(socialLinks, { opacity: 0, x: -15 });
            tl.to(socialLinks, { opacity: 1, x: 0, duration: 0.6, stagger: 0.1 }, 0.7);
          }

          // CTAs
          const ctas = heroSection.querySelectorAll('[data-ctas] a');
          if (ctas.length) {
            gsap.set(ctas, { opacity: 0, y: 15 });
            tl.to(ctas, { opacity: 1, y: 0, duration: 0.6, stagger: 0.1 }, 0.9);
          }

          // Currently section
          const currently = heroSection.querySelector('[data-currently]');
          if (currently) {
            gsap.set(currently, { opacity: 0, y: 10 });
            tl.to(currently, { opacity: 1, y: 0, duration: 0.6 }, 1.1);
          }

          // Subtle cursor-following glow
          const glow = document.createElement('div');
          glow.className = 'hero-glow';
          heroSection.appendChild(glow);
          (heroSection as HTMLElement).style.position = 'relative';
          (heroSection as HTMLElement).style.overflow = 'hidden';

          heroSection.addEventListener('mousemove', (e: Event) => {
            const me = e as MouseEvent;
            const rect = (heroSection as HTMLElement).getBoundingClientRect();
            gsap.to(glow, {
              x: me.clientX - rect.left - 150,
              y: me.clientY - rect.top - 150,
              duration: 0.8,
              ease: 'power2.out',
            });
          });

          heroSection.addEventListener('mouseleave', () => {
            gsap.to(glow, { opacity: 0, duration: 0.5 });
          });

          heroSection.addEventListener('mouseenter', () => {
            gsap.to(glow, { opacity: 1, duration: 0.5 });
          });
        }

        // Magnetic button effect
        document.querySelectorAll('.magnetic-btn').forEach(btn => {
          btn.addEventListener('mousemove', (e: Event) => {
            const me = e as MouseEvent;
            const rect = (btn as HTMLElement).getBoundingClientRect();
            const x = (me.clientX - rect.left - rect.width / 2) * 0.15;
            const y = (me.clientY - rect.top - rect.height / 2) * 0.15;
            gsap.to(btn, { x, y, duration: 0.3, ease: 'power2.out' });
          });
          btn.addEventListener('mouseleave', () => {
            gsap.to(btn, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1, 0.5)' });
          });
        });

        // Scroll-triggered publication cards
        const cards = document.querySelectorAll('.publication-card');
        cards.forEach((card, i) => {
          gsap.set(card, { opacity: 0, y: 30 });
          ScrollTrigger.create({
            trigger: card as HTMLElement,
            start: 'top 90%',
            once: true,
            onEnter: () => {
              gsap.to(card, {
                opacity: 1,
                y: 0,
                duration: 0.7,
                delay: (i % 4) * 0.1,
                ease: 'power2.out',
              });
            },
          });
        });

        // Scroll-triggered reveals
        const scrollRevealEls = document.querySelectorAll('[data-scroll-reveal]');
        scrollRevealEls.forEach((el) => {
          gsap.set(el, { opacity: 0, y: 25 });
          ScrollTrigger.create({
            trigger: el as HTMLElement,
            start: 'top 88%',
            once: true,
            onEnter: () => {
              gsap.to(el, { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' });
            },
          });
        });

        // Scroll-triggered marker highlights (for about page etc)
        document.querySelectorAll('.marker-highlight:not(.revealed)').forEach(marker => {
          ScrollTrigger.create({
            trigger: marker as HTMLElement,
            start: 'top 85%',
            once: true,
            onEnter: () => marker.classList.add('revealed'),
          });
        });

        // About page work cards animation
        const workCards = document.querySelectorAll('[data-work-card]');
        workCards.forEach((card, i) => {
          gsap.set(card, { opacity: 0, x: -20 });
          ScrollTrigger.create({
            trigger: card as HTMLElement,
            start: 'top 88%',
            once: true,
            onEnter: () => {
              gsap.to(card, { opacity: 1, x: 0, duration: 0.6, delay: i * 0.1, ease: 'power2.out' });
            },
          });
        });
      }

      // Run on initial load and after view transitions
      initSmooth();
      document.addEventListener('astro:after-swap', () => {
        ScrollTrigger.getAll().forEach(t => t.kill());
        initSmooth();
      });
    </script>
  </body>
</html>
