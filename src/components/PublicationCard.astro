---
interface Badge {
  text: string;
  type: 'award' | 'status';
}

interface Props {
  title: string;
  year: number;
  authors: string;
  venue: string;
  type: string;
  link: string;
  thumbnail?: string | null;
  badges?: Badge[];
  compact?: boolean;
}

const { title, year, authors, venue, type, link, thumbnail, badges = [], compact = false } = Astro.props;

const thumbnailPath = thumbnail ? `/images/publications/${thumbnail}` : null;
const titleInitial = title.charAt(0).toUpperCase();
---

<article class="publication-card group">
  <a href={link} target="_blank" rel="noopener noreferrer" class="flex flex-col sm:flex-row gap-4 sm:gap-6 no-underline w-full">
    <!-- Thumbnail -->
    {thumbnailPath ? (
      <div class="thumbnail flex-shrink-0">
        <img 
          src={thumbnailPath} 
          alt={title} 
          class="w-full h-auto aspect-video object-contain rounded-md bg-white"
          loading="lazy"
          decoding="async"
          width="192"
          height="108"
        />
      </div>
    ) : (
      <div class="thumbnail flex-shrink-0">
        <div class="thumbnail-placeholder">{titleInitial}</div>
      </div>
    )}
    <!-- Content -->
    <div class="flex-1 min-w-0">
      <!-- Header: Title + Year -->
      <div class="flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-4 mb-2">
        <h3 class="text-base sm:text-lg font-heading font-medium text-ink group-hover:text-cobalt transition-colors flex-1 min-w-0">
          {title}
        </h3>
        <span class="badge-year whitespace-nowrap self-start flex-shrink-0">{year}</span>
      </div>
      
      <!-- Type badge and award badges -->
      <div class="flex flex-wrap gap-2 mb-2">
        <span class="text-xs font-heading text-terracotta font-medium">{type}</span>
        {badges.map(badge => (
          <span class="badge-note">{badge.text}</span>
        ))}
      </div>
      
      <!-- Authors -->
      {!compact && (
        <p class="text-sm text-ink-muted mb-1 line-clamp-2">{authors}</p>
      )}
      
      <!-- Venue -->
      <p class="text-sm text-ink-muted italic line-clamp-1">{venue}</p>
    </div>
  </a>
</article>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
