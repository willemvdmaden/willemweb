---
interface Badge {
  text: string;
  type: 'award' | 'status';
}

interface Props {
  title: string;
  year: number;
  authors: string;
  venue: string;
  type: string;
  link: string;
  thumbnail?: string | null;
  badges?: Badge[];
  compact?: boolean;
}

const { title, year, authors, venue, type, link, thumbnail, badges = [], compact = false } = Astro.props;

// Check if thumbnail exists
const thumbnailPath = thumbnail ? `/images/publications/${thumbnail}` : null;

// Get first letter of title for placeholder
const titleInitial = title.charAt(0).toUpperCase();
---

<article class="publication-card group">
  <a href={link} target="_blank" rel="noopener noreferrer" class="flex flex-col sm:flex-row gap-4 sm:gap-6 no-underline">
    <!-- Thumbnail -->
    {/* Thumbnail (Disabled for now) */}
    {/* {thumbnailPath && (
      <div class="thumbnail">
        <img 
          src={thumbnailPath} 
          alt={title} 
          class="w-full h-auto aspect-video object-cover"
          loading="lazy"
          decoding="async"
          onerror="this.parentElement.style.display='none';"
        />
      </div>
    )} */}
    
    <!-- Content -->
    <div class="flex-1">
      <!-- Header: Title + Year -->
      <div class="grid grid-cols-[1fr_auto] gap-4 mb-2 items-start">
        <h3 class="text-lg font-heading font-medium text-ink group-hover:text-cobalt transition-colors">
          {title}
        </h3>
        <span class="badge-year whitespace-nowrap">{year}</span>
      </div>
      
      <!-- Type badge and award badges -->
      <div class="flex flex-wrap gap-2 mb-2">
        <span class="text-xs font-heading text-terracotta font-medium">{type}</span>
        {badges.map(badge => (
          <span class="badge-note">{badge.text}</span>
        ))}
      </div>
      
      <!-- Authors -->
      {!compact && (
        <p class="text-sm text-ink-muted mb-1 line-clamp-2">{authors}</p>
      )}
      
      <!-- Venue -->
      <p class="text-sm text-ink-muted italic line-clamp-1">{venue}</p>
    </div>
  </a>
</article>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  

</style>
