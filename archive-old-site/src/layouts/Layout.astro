---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Postdoctoral Researcher at IT University of Copenhagen, researching AI, Design, and Human-Computer Interaction" } = Astro.props;
const fullTitle = title === "Willem van der Maden" ? title : `${title} | Willem van der Maden`;

import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/icon.png" />
    
    <!-- Fonts: Sora (headings) + Lora (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
    
    <ViewTransitions />
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Grain overlay -->
    <div class="grain-overlay" aria-hidden="true"></div>
    
    <Header />
    <main class="flex-grow mb-16 md:mb-24">
      <slot />
    </main>
    <Footer />

    <script>
      import Lenis from 'lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      function initSmooth() {
        // Lenis smooth scroll
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        });

        lenis.on('scroll', ScrollTrigger.update);

        gsap.ticker.add((time: number) => {
          lenis.raf(time * 1000);
        });
        gsap.ticker.lagSmoothing(0);

        // Hero animations
        const heroSection = document.querySelector('[data-hero]');
        if (heroSection) {
          const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

          // Name reveal with letter-spacing
          const h1 = heroSection.querySelector('h1');
          if (h1) {
            gsap.set(h1, { opacity: 0, y: 30, letterSpacing: '0.15em' });
            tl.to(h1, { opacity: 1, y: 0, letterSpacing: '-0.02em', duration: 1 }, 0.1);
          }

          // Subtitle
          const subtitle = heroSection.querySelector('[data-subtitle]');
          if (subtitle) {
            gsap.set(subtitle, { opacity: 0, y: 20 });
            tl.to(subtitle, { opacity: 1, y: 0, duration: 0.8 }, 0.3);
          }

          // Profile image
          const img = heroSection.querySelector('img');
          if (img) {
            gsap.set(img, { opacity: 0, scale: 0.9 });
            tl.to(img, { opacity: 1, scale: 1, duration: 0.8 }, 0.4);
          }

          // Social links staggered
          const socialLinks = heroSection.querySelectorAll('[data-social] a');
          if (socialLinks.length) {
            gsap.set(socialLinks, { opacity: 0, x: -15 });
            tl.to(socialLinks, { opacity: 1, x: 0, duration: 0.6, stagger: 0.1 }, 0.5);
          }

          // Bio text
          const bio = heroSection.querySelector('[data-bio]');
          if (bio) {
            gsap.set(bio, { opacity: 0, y: 20 });
            tl.to(bio, { opacity: 1, y: 0, duration: 0.8 }, 0.7);
          }

          // CTAs
          const ctas = heroSection.querySelectorAll('[data-ctas] a');
          if (ctas.length) {
            gsap.set(ctas, { opacity: 0, y: 15 });
            tl.to(ctas, { opacity: 1, y: 0, duration: 0.6, stagger: 0.1 }, 0.9);
          }

          // Subtle cursor-following glow
          const glow = document.createElement('div');
          glow.className = 'hero-glow';
          heroSection.appendChild(glow);
          (heroSection as HTMLElement).style.position = 'relative';
          (heroSection as HTMLElement).style.overflow = 'hidden';

          heroSection.addEventListener('mousemove', (e: Event) => {
            const me = e as MouseEvent;
            const rect = (heroSection as HTMLElement).getBoundingClientRect();
            const x = me.clientX - rect.left;
            const y = me.clientY - rect.top;
            gsap.to(glow, {
              x: x - 150,
              y: y - 150,
              duration: 0.8,
              ease: 'power2.out',
            });
          });

          heroSection.addEventListener('mouseleave', () => {
            gsap.to(glow, { opacity: 0, duration: 0.5 });
          });

          heroSection.addEventListener('mouseenter', () => {
            gsap.to(glow, { opacity: 1, duration: 0.5 });
          });
        }

        // Scroll-triggered publication cards
        const cards = document.querySelectorAll('.publication-card');
        cards.forEach((card, i) => {
          gsap.set(card, { opacity: 0, y: 30 });
          ScrollTrigger.create({
            trigger: card as HTMLElement,
            start: 'top 90%',
            once: true,
            onEnter: () => {
              gsap.to(card, {
                opacity: 1,
                y: 0,
                duration: 0.7,
                delay: (i % 4) * 0.08,
                ease: 'power2.out',
              });
            },
          });
        });

        // Scroll-triggered blog posts and about sections
        const scrollRevealEls = document.querySelectorAll('[data-scroll-reveal]');
        scrollRevealEls.forEach((el) => {
          gsap.set(el, { opacity: 0, y: 25 });
          ScrollTrigger.create({
            trigger: el as HTMLElement,
            start: 'top 88%',
            once: true,
            onEnter: () => {
              gsap.to(el, { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' });
            },
          });
        });
      }

      // Run on initial load and after view transitions
      initSmooth();
      document.addEventListener('astro:after-swap', () => {
        ScrollTrigger.getAll().forEach(t => t.kill());
        initSmooth();
      });
    </script>
  </body>
</html>
