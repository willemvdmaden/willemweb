---
import Layout from '../layouts/Layout.astro';

import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout 
  title="Blog" 
  description="Thoughts on AI, Design, and Human-Computer Interaction"
>
  <section class="container-content py-12 md:py-16">
    <h1 class="mb-2">Blog</h1>
    <p class="text-ink-muted text-lg mb-10">
      Thoughts on AI, Design, and Human-Computer Interaction
    </p>
    
    <div class="space-y-6">
      {posts.map(post => (
        <article class="p-6 rounded-md hover:bg-cream-dark hover:shadow-soft hover:-translate-y-[1px] transition-all duration-200 ease-in-out">
          <a href={`/blog/${post.slug}`} class="no-underline block">
            <div class="flex items-baseline justify-between gap-4 mb-2">
              <h2 class="text-xl font-heading font-medium text-ink hover:text-cobalt transition-colors">
                {post.data.title}
              </h2>
              <span class="text-sm text-ink-muted whitespace-nowrap">
                {post.data.pubDate.toLocaleDateString('en-us', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </span>
            </div>
            <p class="text-ink-muted">{post.data.description}</p>
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
