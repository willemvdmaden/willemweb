---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="About" 
  description="About Willem van der Maden - AI Design Researcher at IT University of Copenhagen"
>
  <!-- Bio Section -->
  <section class="container-content py-12 md:py-16">
    <h1 class="mb-2">About</h1>
    <p class="text-ink-muted text-lg mb-10"></p>
    
    <div class="prose max-w-none space-y-6 text-lg">
      <p>
        I'm Dr. Willem van der Maden, a researcher at the IT University of Copenhagen, exploring how people interact with AI to design systems that enhance wellbeing and improve user experiences.
      </p>
      
      <p>
        My research focuses on developing frameworks and methodologies for designing AI systems that actively promote wellbeing and human flourishing. I'm particularly interested in how we can create AI technologies that not only avoid harm but actively contribute to individual and community wellbeing.
      </p>
      
      <p>
        Through my work, I aim to bridge the gap between AI technology and human needs, ensuring that our advances in artificial intelligence are aligned with human values and promote positive outcomes for society.
      </p>
    </div>
  </section>
  
  <!-- Work History Section -->
  <section class="container-content py-12 md:py-16 border-t border-border">
    <div class="sm:flex sm:gap-16">
      <h2 class="text-ink-muted text-lg font-heading mb-8 sm:mb-0 sm:w-24 flex-shrink-0">Work</h2>
      
      <div class="flex-1">
        <p class="mb-6 text-ink-muted">
          Key positions throughout my career:
        </p>
        
        <div class="space-y-4">
          <!-- ITU Copenhagen -->
          <a 
             href="https://www.itu.dk/" 
             target="_blank" 
             rel="noopener noreferrer"
             class="flex items-center justify-between p-4 rounded-md hover:bg-cream-dark hover:shadow-soft hover:-translate-y-[1px] transition-all duration-200 ease-in-out no-underline group"
          >
            <div class="flex items-center gap-4">
              <img 
                src="/itu.webp" 
                alt="IT University of Copenhagen" 
                class="w-10 h-10 rounded-full object-cover"
                width="40"
                height="40"
              />
              <div>
                <h3 class="font-heading font-medium text-ink group-hover:text-cobalt transition-colors">
                  Postdoctoral Researcher
                </h3>
                <p class="text-sm text-ink-muted">IT University of Copenhagen</p>
              </div>
            </div>
            <span class="text-sm text-ink-muted">Jan 2024 – Present</span>
          </a>
          
          <!-- TU Delft -->
          <a 
             href="https://www.tudelft.nl/" 
             target="_blank" 
             rel="noopener noreferrer"
             class="flex items-center justify-between p-4 rounded-md hover:bg-cream-dark hover:shadow-soft hover:-translate-y-[1px] transition-all duration-200 ease-in-out no-underline group"
          >
            <div class="flex items-center gap-4">
              <img 
                src="/flame.png" 
                alt="TU Delft" 
                class="w-10 h-10 rounded-full object-cover bg-white"
                width="40"
                height="40"
              />
              <div>
                <h3 class="font-heading font-medium text-ink group-hover:text-cobalt transition-colors">
                  Ph.D. Candidate
                </h3>
                <p class="text-sm text-ink-muted">TU Delft</p>
              </div>
            </div>
            <span class="text-sm text-ink-muted">Dec 2019 – Dec 2023</span>
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Connect Section -->
  <section class="container-content py-12 md:py-16 border-t border-border">
    <div class="sm:flex sm:gap-16">
      <h2 class="text-ink-muted text-lg font-heading mb-8 sm:mb-0 sm:w-24 flex-shrink-0">Connect</h2>
      
      <div class="flex-1">
        <p class="mb-6 text-ink-muted">
          Feel free to connect with me through any of these platforms:
        </p>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <a 
             href="https://www.linkedin.com/in/wlavandermaden/" 
             target="_blank" 
             rel="noopener noreferrer"
             class="flex items-center gap-3 p-4 rounded-md border border-border hover:border-cobalt hover:shadow-soft hover:-translate-y-[1px] hover:text-cobalt transition-all duration-200 ease-in-out no-underline group"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-ink-muted group-hover:text-cobalt transition-colors">
              <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93zM6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37z"/>
            </svg>
            <span class="flex-1 font-heading text-ink group-hover:text-cobalt transition-colors">LinkedIn</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink-muted group-hover:text-cobalt transition-colors rotate-45">
              <path d="M12 5v14M5 12h14"/>
            </svg>
          </a>
          
          <a 
             href="https://scholar.google.com/citations?user=_9ZGOcAAAAAJ&hl=da" 
             target="_blank" 
             rel="noopener noreferrer"
             class="flex items-center gap-3 p-4 rounded-md border border-border hover:border-cobalt hover:shadow-soft hover:-translate-y-[1px] hover:text-cobalt transition-all duration-200 ease-in-out no-underline group"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-ink-muted group-hover:text-cobalt transition-colors">
              <path d="M12 3L1 9l11 6l9-4.91V17h2V9M5 13.18v4L12 21l7-3.82v-4L12 17z"/>
            </svg>
            <span class="flex-1 font-heading text-ink group-hover:text-cobalt transition-colors">Google Scholar</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink-muted group-hover:text-cobalt transition-colors rotate-45">
              <path d="M12 5v14M5 12h14"/>
            </svg>
          </a>
          
          <a 
            href="mailto:willem.maden@gmail.com"
            class="flex items-center gap-3 p-4 rounded-md border border-border hover:border-cobalt hover:shadow-soft hover:-translate-y-[1px] hover:text-cobalt transition-all duration-200 ease-in-out no-underline group"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-ink-muted group-hover:text-cobalt transition-colors">
              <path d="m20 8l-8 5l-8-5V6l8 5l8-5m0-2H4c-1.11 0-2 .89-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2"/>
            </svg>
            <span class="flex-1 font-heading text-ink group-hover:text-cobalt transition-colors">Email</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink-muted group-hover:text-cobalt transition-colors rotate-45">
              <path d="M12 5v14M5 12h14"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
